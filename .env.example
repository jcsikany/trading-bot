# ============================
# BINANCE API
# ============================
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# ============================
# MODO DE TRADING
# true  = Paper trading (simulado, sin dinero real)
# false = Live trading (dinero real - ¡cuidado!)
# ============================
PAPER_TRADING=true

# Capital inicial en USDT
INITIAL_CAPITAL=200

# ============================
# BASE DE DATOS (Railway PostgreSQL)
# ============================
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============================
# NOTIFICACIONES (Expo Push)
# Reutilizar el token de tus otras apps
# ============================
EXPO_PUSH_TOKEN=ExponentPushToken[xxxxxxxxxxxxxxxxxxxxxx]

# ============================
# SERVIDOR
# ============================
PORT=3000
NODE_ENV=production
